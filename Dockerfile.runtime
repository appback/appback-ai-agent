FROM node:22-bookworm-slim

ARG APPBACK_AI_AGENT_VERSION=2.4.0

RUN npm install --global "appback-ai-agent@${APPBACK_AI_AGENT_VERSION}" \
    && npm cache clean --force \
    && mkdir -p /app/config /app/data /app/models /app/training \
    && chown -R node:node /app

COPY docker/runtime-entrypoint.sh /usr/local/bin/appback-ai-agent-runtime
RUN chmod 0755 /usr/local/bin/appback-ai-agent-runtime

WORKDIR /app
USER node

ENTRYPOINT ["appback-ai-agent-runtime"]

