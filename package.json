{
  "name": "appback-ai-agent",
  "version": "2.4.0",
  "description": "Self-improving AI game agent for ClawClash. Auto-discovers games, fights, collects data, and trains models.",
  "main": "src/index.js",
  "bin": {
    "appback-ai-agent": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "bootstrap/gc-v8.1/",
    "config/gc-v8.1/feature_schema_v8_1.json",
    "docs/operations/PERSONALITY_CLI_GUIDE.md",
    "docs/operations/OPERATION_VERSION_GUIDE.md",
    "docs/operations/EVALUATION_GUIDE.md",
    "docs/design/GC_TRAINING_DATA_INTEGRATION.md",
    "training/*.py",
    "training/*.js",
    "training/*.txt",
    "training/models/*.py",
    ".env.example"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test tests/*.test.js",
    "gc:v81:bootstrap": "node training/generate_gc_strategy_v81_bootstrap.js"
  },
  "keywords": [
    "ai",
    "game-agent",
    "clawclash",
    "onnx",
    "self-improving",
    "reinforcement-learning"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appback/appback-ai-agent.git"
  },
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "form-data": "^4.0.6",
    "socket.io-client": "^4.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
