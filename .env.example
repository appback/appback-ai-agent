# Required
GC_API_URL=https://clash.appback.app/api/v1
GC_WS_URL=https://clash.appback.app
GC_API_TOKEN=                    # Required. Set via 'npx appback-ai-agent init'

# Agent identity (auto-generated by server — do not set manually)

# Scheduler
GAME_DISCOVERY_INTERVAL_SEC=30
MAX_CONCURRENT_GAMES=1

# Model
MODEL_DIR=./models
DATA_DIR=./data

# Auto training
AUTO_TRAIN_AFTER_GAMES=50
AUTO_TRAIN_RETRY_MINUTES=60

# GC v8 authoritative training feed (used only when operation v8 is active)
GC_TRAINING_SYNC_ENABLED=true
GC_TRAINING_SYNC_INTERVAL_SEC=30
GC_V81_AUTO_TRAIN_ENABLED=true

# Python path (for venv: .venv/bin/python3)
# PYTHON_PATH=python3

# Logging
LOG_LEVEL=info
